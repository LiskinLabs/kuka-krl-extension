    "tokenColors": [
        {
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": { "foreground": "#4a4a4a", "fontStyle": "italic" }
        },
        {
            "scope": ["string"],
            "settings": { "foreground": "#69F0AE" }
        },
        {
            "scope": ["constant.numeric"],
            "settings": { "foreground": "#FFAB40" }
        },
        {
            "scope": ["constant.language", "constant.other"],
            "settings": { "foreground": "#FF8A80" }
        },
        {
            "scope": ["keyword.operator"],
            "settings": { "foreground": "#b0b0b0" }
        },
        {
            "scope": ["storage.type", "storage.modifier"],
            "settings": { "foreground": "#18FFFF" }
        },
        {
            "scope": ["support.function"],
            "settings": { "foreground": "#40C4FF" }
        },
        {
            "name": "KRL Comments",
            "scope": [
                "comment.line",
                "comment.line.semicolon.krl",
                "comment.line.ampersand.krl",
                "comment.line.bug.krl",
                "comment.line.fixme.krl",
                "comment.line.hack.krl",
                "comment.line.note.krl",
                "comment.line.todo.krl"
            ],
            "settings": { "foreground": "#4a4a4a", "fontStyle": "italic" }
        },
        {
            "name": "KRL Fold Markers",
            "scope": ["comment.line.fold.krl", "meta.fold.krl", "keyword.control.fold.krl"],
            "settings": { "foreground": "#4d6653", "fontStyle": "italic" }
        },
        {
            "name": "KRL Control Keywords",
            "scope": ["keyword.control.krl"],
            "settings": { "foreground": "#EA80FC", "fontStyle": "bold" }
        },
        {
            "name": "KRL Movement Commands",
            "scope": ["keyword.function.movement.krl"],
            "settings": { "foreground": "#00E5FF", "fontStyle": "bold" }
        },
        {
            "name": "KRL Storage/Types",
            "scope": ["storage.type.krl", "storage.type.interrupt.krl", "storage.type.trigger.krl"],
            "settings": { "foreground": "#18FFFF", "fontStyle": "italic" }
        },
        {
            "name": "KRL System Variables",
            "scope": ["variable.language.system.krl"],
            "settings": { "foreground": "#FF5252", "fontStyle": "" }
        },
        {
            "name": "KRL Numbers",
            "scope": ["constant.numeric.krl", "constant.numeric.hex.krl", "constant.numeric.binary.krl"],
            "settings": { "foreground": "#FFAB40" }
        },
        {
            "name": "KRL Strings",
            "scope": ["string.quoted.double.krl"],
            "settings": { "foreground": "#69F0AE" }
        },
        {
            "name": "KRL User Functions",
            "scope": ["variable.function.krl"],
            "settings": { "foreground": "#40C4FF" }
        },
        {
            "name": "KRL Enums",
            "scope": ["constant.language.enum.krl", "variable.other.enummember.krl"],
            "settings": { "foreground": "#FF8A80" }
        },
        {
            "name": "KRL Built-in Functions",
            "scope": ["support.function.builtin.krl"],
            "settings": { "foreground": "#00E5FF" }
        },
        {
            "name": "KRL Operators",
            "scope": [
                "keyword.operator.krl",
                "keyword.operator.comparison.krl",
                "keyword.operator.arithmetic.krl",
                "keyword.operator.bitwise.krl",
                "keyword.operator.logical.krl"
            ],
            "settings": { "foreground": "#b0b0b0" }
        }
    ]
}
