{
  "name": "kuka-krl-extension",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "1.7.2",
  "icon": "logo.png",
  "publisher": "LiskinLabs",
  "author": {
    "name": "Liskin Labs",
    "email": "silvlis@outlook.com",
    "url": "https://github.com/LiskinLabs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LiskinLabs/kuka-krl-extension.git"
  },
  "license": "SEE LICENSE IN LICENSE.txt",
  "sponsor": {
    "url": "https://github.com/LiskinLabs/kuka-krl-extension#support-the-project"
  },
  "homepage": "https://github.com/LiskinLabs/kuka-krl-extension",
  "bugs": {
    "url": "https://github.com/LiskinLabs/kuka-krl-extension/issues"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters",
    "Themes"
  ],
  "keywords": [
    "kuka",
    "krl",
    "robot",
    "industrial",
    "automation",
    "robotics",
    "kuka robot language"
  ],
  "galleryBanner": {
    "color": "#FF6600",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./client/out/main.js",
  "activationEvents": [],
  "contributes": {
    "languages": [
      {
        "id": "krl",
        "aliases": [
          "KUKA KRL",
          "krl"
        ],
        "extensions": [
          ".src",
          ".dat",
          ".sub"
        ],
        "configuration": "./client/krl-language-configuration.json"
      }
    ],
    "snippets": [
      {
        "language": "krl",
        "path": "./client/snippets/krl.code-snippets"
      }
    ],
    "grammars": [
      {
        "language": "krl",
        "scopeName": "source.krl",
        "path": "./client/syntaxes/krl.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "KRL Industrial Dark",
        "uiTheme": "vs-dark",
        "path": "./client/themes/KRL_Industrial_Dark.json"
      },
      {
        "label": "KRL Industrial Light",
        "uiTheme": "vs",
        "path": "./client/themes/KRL_Industrial_Light.json"
      },
      {
        "label": "KRL Midnight OLED",
        "uiTheme": "vs-dark",
        "path": "./client/themes/KRL_Midnight_OLED.json"
      },
      {
        "label": "KRL Blueprint",
        "uiTheme": "vs-dark",
        "path": "./client/themes/KRL_Blueprint.json"
      },
      {
        "label": "KRL WorkVisual Dark (Standard)",
        "uiTheme": "vs-dark",
        "path": "./client/themes/KRL_WorkVisual_Dark.json"
      },
      {
        "label": "KRL WorkVisual Light (Standard)",
        "uiTheme": "vs",
        "path": "./client/themes/KRL_WorkVisual_Light.json"
      }
    ],
    "iconThemes": [
      {
        "id": "krl-icons",
        "label": "KRL File Icons",
        "path": "./client/krl-icon-theme.json"
      }
    ],
    "commands": [
      {
        "command": "krl.validateWorkspace",
        "title": "%command.validateWorkspace%",
        "category": "KRL",
        "icon": "$(check-all)"
      },
      {
        "command": "krl.foldAll",
        "title": "%command.foldAll%",
        "category": "KRL",
        "icon": "$(fold)"
      },
      {
        "command": "krl.unfoldAll",
        "title": "%command.unfoldAll%",
        "category": "KRL",
        "icon": "$(unfold)"
      },
      {
        "command": "krl.formatDocument",
        "title": "%command.formatDocument%",
        "category": "KRL",
        "icon": "$(code)"
      },
      {
        "command": "krl.removeTrailingWhitespace",
        "title": "%command.removeTrailingWhitespace%",
        "category": "KRL",
        "icon": "$(whitespace)"
      },
      {
        "command": "krl.sortDeclarations",
        "title": "%command.sortDeclarations%",
        "category": "KRL",
        "icon": "$(list-ordered)"
      },
      {
        "command": "krl.insertFold",
        "title": "%command.insertFold%",
        "category": "KRL",
        "icon": "$(symbol-namespace)"
      },
      {
        "command": "krl.refreshIOView",
        "title": "%command.refreshIOView%",
        "category": "KRL",
        "icon": "$(refresh)"
      },
      {
        "command": "krl.cleanupUnusedVariables",
        "title": "%command.cleanupUnusedVariables%",
        "category": "KRL",
        "icon": "$(trash)"
      },
      {
        "command": "krl.showCalculator",
        "title": "%command.showCalculator%",
        "category": "KRL",
        "icon": "$(calculator)"
      },
      {
        "command": "krl.renameSignal",
        "title": "%command.renameSignal%",
        "category": "KRL",
        "icon": "$(edit)"
      },
      {
        "command": "krl.openSnippetGenerator",
        "title": "KRL Snippet Generator",
        "category": "KRL",
        "icon": "$(beaker)"
      },
      {
        "command": "krl.generateReport",
        "title": "Generate Analysis Report",
        "category": "KRL",
        "icon": "$(report)"
      },
      {
        "command": "krl.showFlowchart",
        "title": "Show Control Flow Graph",
        "category": "KRL",
        "icon": "$(git-merge)"
      },
      {
        "command": "krl.activateLicense",
        "title": "Activate Pro License",
        "category": "KRL",
        "icon": "$(key)"
      },
      {
        "command": "krl.deactivateLicense",
        "title": "Deactivate Pro License",
        "category": "KRL",
        "icon": "$(lock)"
      },
      {
        "command": "krl.checkLicenseStatus",
        "title": "Check License Status",
        "category": "KRL",
        "icon": "$(info)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "krlIO",
          "name": "KRL I/O Signals",
          "when": "workbenchState != empty"
        },
        {
          "id": "krlCommands",
          "name": "KUKA Commands",
          "when": "workbenchState != empty"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "krlIO",
        "contents": "%view.krlIO.welcome%\n[Refresh](command:krl.refreshIOView)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "krl.foldAll",
          "group": "navigation@1",
          "when": "resourceLangId == krl"
        },
        {
          "command": "krl.unfoldAll",
          "group": "navigation@2",
          "when": "resourceLangId == krl"
        },
        {
          "command": "krl.formatDocument",
          "group": "navigation@3",
          "when": "resourceLangId == krl"
        },
        {
          "command": "krl.validateWorkspace",
          "group": "navigation@4",
          "when": "resourceLangId == krl"
        },
        {
          "command": "krl.showCalculator",
          "group": "navigation@5",
          "when": "resourceLangId == krl"
        },
        {
          "command": "krl.openSnippetGenerator",
          "group": "navigation@6",
          "when": "resourceLangId == krl"
        },
        {
          "command": "krl.refreshIOView",
          "group": "navigation@7",
          "when": "resourceLangId == krl"
        },
        {
          "command": "krl.showFlowchart",
          "group": "navigation@1",
          "when": "resourceLangId == krl"
        }
      ],
      "editor/context": [
        {
          "command": "krl.validateWorkspace",
          "group": "1_modification@1",
          "when": "resourceLangId == krl"
        },
        {
          "command": "krl.formatDocument",
          "group": "1_modification@2",
          "when": "resourceLangId == krl"
        },
        {
          "command": "krl.removeTrailingWhitespace",
          "group": "1_modification@3",
          "when": "resourceLangId == krl"
        },
        {
          "command": "krl.sortDeclarations",
          "group": "1_modification@4",
          "when": "resourceLangId == krl"
        },
        {
          "command": "krl.insertFold",
          "group": "1_modification@5",
          "when": "resourceLangId == krl"
        },
        {
          "command": "krl.cleanupUnusedVariables",
          "group": "1_modification@6",
          "when": "resourceLangId == krl"
        },
        {
          "command": "krl.showCalculator",
          "group": "1_modification@7",
          "when": "resourceLangId == krl"
        },
        {
          "command": "krl.openSnippetGenerator",
          "group": "1_modification@8",
          "when": "resourceLangId == krl"
        },
        {
          "command": "krl.renameSignal",
          "group": "1_modification@9",
          "when": "resourceLangId == krl"
        },
        {
          "command": "krl.showFlowchart",
          "group": "1_modification@10",
          "when": "resourceLangId == krl"
        }
      ],
      "view/title": [
        {
          "command": "krl.refreshIOView",
          "when": "view == krlIO",
          "group": "navigation"
        },
        {
          "command": "krl.generateReport",
          "when": "view == krlCommands",
          "group": "navigation"
        },
        {
          "command": "krl.showCalculator",
          "when": "view == krlCommands",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "krl.showCalculator",
          "when": "view == krlCommands",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "krl.autoFold": {
          "type": "boolean",
          "default": false,
          "description": "%config.autoFold.description%"
        },
        "krl.formatOnSave": {
          "type": "boolean",
          "default": false,
          "description": "%config.formatOnSave.description%"
        },
        "krl.removeTrailingWhitespaceOnFormat": {
          "type": "boolean",
          "default": true,
          "description": "%config.removeTrailingWhitespaceOnFormat.description%"
        },
        "krl.indentWidth": {
          "type": "integer",
          "default": 3,
          "minimum": 1,
          "maximum": 8,
          "description": "%config.indentWidth.description%"
        },
        "krl.separateBeforeBlocks": {
          "type": "boolean",
          "default": false,
          "description": "%config.separateBeforeBlocks.description%"
        },
        "krl.separateAfterBlocks": {
          "type": "boolean",
          "default": false,
          "description": "%config.separateAfterBlocks.description%"
        },
        "krl.validateNonAscii": {
          "type": "boolean",
          "default": true,
          "description": "%config.validateNonAscii.description%"
        },
        "krl.indentFolds": {
          "type": "boolean",
          "default": true,
          "description": "%config.indentFolds%"
        },
        "krl.alignAssignments": {
          "type": "boolean",
          "default": true,
          "description": "%config.alignAssignments%"
        },
        "krl.inlayHints.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show descriptive names for I/O signals and system data as inline hints."
        },
        "krl.errorLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show diagnostics as inline text (Error Lens style)."
        },
        "krl.codeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show CodeLens hints for references and documentation."
        },
        "krl.callHierarchy.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Call Hierarchy support for functions."
        },
        "krl.documentHighlights.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Highlight occurrences of the same variable/function in the document."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "compile": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "lint": "eslint .",
    "package": "vsce package",
    "test": "node tests/extension.test.js"
  },
  "devDependencies": {
    "@types/node": "^20.17.23",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "@vscode/vsce": "^2.32.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "javascript-obfuscator": "^5.4.3",
    "prettier": "^3.7.4",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "@types/vscode": "^1.109.0",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.1.0"
  }
}
